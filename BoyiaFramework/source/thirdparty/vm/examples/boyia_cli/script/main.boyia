class Printer {
    fun say(msg) {
        BY_Log(msg);
    }
};
class MyAdd {
    fun add(a, b) {
        return a+b;
    }
}
var p = new(Printer);
fun printlog(p, str) {
    p.say(str);
}
printlog(p, "hello");    
printlog(p, "world");

var a = new(MyAdd);
printlog(p, "result:" + a.add(100,202));

var arr1 = ["789", "100"];
printlog(p, arr1.get(0));

var body = {
    "Content-Type" : "application/x-www-form-urlencoded",
    "User-Token" : "1234567890",
    body : "name=test&pwd=test",
    items : ["123", "456"]
};
printlog(p, body.get("body"));

class Util {
    fun newMicrotask(worker) {
        BY_Log("call newMicrotask");
        var task = new(MicroTask);
        BY_Log("call MicroTask create");
        task.init(worker);
        BY_Log("call MicroTask init");
        return task;
    }
}

class PrinterExt extends Printer {
    prop fun multiply(a, b) {
        return a*b;
    }

    prop fun load() {
        Https.load("https://httpbin.org/get", fun(body) {
            var result = body;
            BY_Log("Https.load result: " + body);
        });
    }

    prop fun demoFile() {
        File.write("boyia_cli_demo.txt", "hello from File.write", fun(err) {
            if (err == "ok") {
                BY_Log("File.write ok");
            } else {
                BY_Log("File.write: " + err);
            }
            
        });

        File.read("boyia_cli_demo.txt", fun(content) {
            BY_Log("File.read: " + content);
        });
    }

    prop async writeFile(content) {
        var result = (await this.writeFilePromise(content));
        if (result == "ok") {
            BY_Log("writeFile ok");
        } else {
            BY_Log("writeFile: " + result);
        }

        BY_Log("write finish");

        File.read("boyia_cli_demo.txt", fun(content) {
            BY_Log("File.read: " + content);
        });
    }

    prop async writeFilePromise(content) {
        BY_Log("run writeFilePromise");
        BY_Log(content);
        Util.newMicrotask(fun(resolve) {
            BY_Log("run writeFilePromise1");
            File.write("boyia_cli_demo.txt", content, resolve);
        });
    }

    prop async loadAsync(url) {
        for (var i = 0; i < 10; i=i+1) {
            if (i == 6) {
                break;
            }
            BY_Log("loadAsync loop: " + i);
        }
    
        var result = (await this.loadPromise(url));
        var test = "hello : " + result;
        BY_Log("loadAsync result: " + test);

        
        return result;
    }

    prop async loadPromise(url) {
        BY_Log("run loadPromise");
        Util.newMicrotask(fun(resolve) {
            BY_Log("run newMicrotask");
            Https.load(url, resolve);
        });
    }

    prop fun testLocal() {
        var test = "hello";
        for (var i = 0; i < 10; i=i+1) {
            var test = "world";
            if (i == 6) {
                break;
            }
            BY_Log("testLocal loop: " + i + test);
        }

        BY_Log("testLocal result: " + test);
    }
}

var pe = new(PrinterExt);
printlog(p, pe.multiply(30, 41));
printlog(pe, pe.multiply(30, 42));
BY_Log(123);
//pe.load();

pe.loadAsync("https://httpbin.org/get");
//pe.demoFile();
//pe.testLocal();
pe.writeFile("hello from File.write");
pe.writeFile("hello from File.write");

printlog(p, arr1.get(0));

arr1.add("811");
printlog(p, arr1.get(1));
printlog(p, arr1.get(2));

