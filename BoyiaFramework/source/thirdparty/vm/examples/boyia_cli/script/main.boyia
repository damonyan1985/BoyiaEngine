require("./util/util.boyia");

class Printer {
    fun say(msg) {
        Util.log(msg);
    }
};
class MyAdd {
    fun add(a, b) {
        return a+b;
    }
}
var p = new(Printer);
fun printlog(p, str) {
    p.say(str);
}
printlog(p, "hello");    
printlog(p, "world");

var a = new(MyAdd);
printlog(p, "result:" + a.add(100,202));

var arr1 = ["789", "100"];
printlog(p, arr1.get(0));

