    "Content-Type" : "application/x-www-form-urlencoded",
    "User-Token" : "1234567890",
    body : "name=test&pwd=test",
    items : ["123", "456"]
};
printlog(p, body.get("body"));

class PrinterExt extends Printer {
    prop fun multiply(a, b) {
        return a*b;
    }

    prop fun load() {
        Https.load("https://httpbin.org/get", fun(res) {
            if (res.get("status") == "ok") {
                var body = res.get("data");
                if (body == null) {
                    body = "";
                }
                Util.log("Https.load result: " + body);
            } else {
                Util.log("Https.load: " + res.get("message"));
            }
        });
    }

    prop fun demoFile() {
        File.write("boyia_cli_demo.txt", "hello from File.write", fun(res) {
            if (res.get("status") == "ok") {
                Util.log("File.write ok");
            } else {
                Util.log("File.write: " + res.get("message"));
            }
        });

        File.read("boyia_cli_demo.txt", fun(res) {
            if (res.get("status") == "ok") {
                Util.log("File.read: " + res.get("data"));
            } else {
                Util.log("File.read: " + res.get("message"));
            }
        });
    }

    prop async writeFile(content) {
        var result = (await this.writeFilePromise(content));
        if (result.get("status") == "ok") {
            Util.log("writeFile ok");
        } else {
            Util.log("writeFile: " + result.get("message"));
        }

        Util.log("write finish");

        var a = 1.234;
        var b = 3;
        var c = a + b;
        if (1 == 1.0) {
            Util.log("1 == 1.0");
        }

        if (b > a && 0 == 0.0) {
            Util.log("a+b=" + c);
            Util.log("" + a);
            Util.log(c);
        }

        File.read("boyia_cli_demo.txt", fun(res) {
            if (res.get("status") == "ok") {
                Util.log("File.read: " + res.get("data"));
            } else {
                Util.log("File.read: " + res.get("message"));
            }
        });
    }

    prop async writeFilePromise(content) {
        Util.log("run writeFilePromise");
        Util.log(content);
        Util.newMicrotask(fun(resolve) {
            Util.log("run writeFilePromise1");
            File.write("boyia_cli_demo.txt", content, resolve);
        });
    }

    prop async loadAsync(url) {
        for (var i = 0; i < 10; i=i+1) {
            if (i == 6) {
                break;
            }
            Util.log("loadAsync loop: " + i);
        }
    
        var result = (await this.loadPromise(url));
        Util.log("loadAsync status: " + result.status);
        if (result.status == "fail") {
            Util.log("loadAsync fail: " + result.message);
            return;
        }
        var payload = result.get("data");
        if (payload == null) {
            Util.log("loadAsync ok no data");
            return;
        }

        var msg = result.get("message");
        if (msg != null) {
            Util.log("loadAsync fail: " + msg);
            return;
        }

        Util.log("loadAsync payload : " + payload);
        var test = "hello : " + payload;
        Util.log("loadAsync result: " + test);

        return payload;
    }

    prop async loadPromise(url) {
        Util.log("run loadPromise");
        Util.newMicrotask(fun(resolve) {
            Util.log("run newMicrotask");
            Https.load(url, resolve);
        });
    }

    prop fun testLocal() {
        var test = "hello";
        for (var i = 0; i < 10; i=i+1) {
            var test = "world";
            if (i == 6) {
                break;
            }
            Util.log("testLocal loop: " + i + test);
        }

        Util.log("testLocal result: " + test);
    }

    prop async zipFile() {
        var result = (await this.zipAsync("E:\work\project\BoyiaEngine\BoyiaTools\boyia-ide\boyia\script\test", "E:\work\project\BoyiaEngine\BoyiaTools\boyia-ide\boyia\script\test.zip", "123456"));
        if (result.get("status") == "ok") {
            Util.log("zipAsync ok");
        } else {
            Util.log("zipAsync: " + result.get("message"));
        }

        result = (await this.unzipAsync("E:\work\project\BoyiaEngine\BoyiaTools\boyia-ide\boyia\script\test.zip", "E:\work\project\BoyiaEngine\BoyiaTools\boyia-ide\boyia\script\test1", "123456"));
        if (result.get("status") == "ok") {
            Util.log("unzipAsync ok");
        } else {
            Util.log("unzipAsync: " + result.get("message"));
        }
    }

    prop async zipAsync(src, dest, password) {
        Util.newMicrotask(fun(resolve) {
            Util.log("run zipAsync");
            Zip.compress(src, dest, password, resolve);
        });
    }

    prop async unzipAsync(src, dest, password) {
        Util.newMicrotask(fun(resolve) {
            Util.log("run unzipAsync");
            Zip.extract(src, dest, password, resolve);
        });
    }

    prop async createDirsDemo() {
        var result = (await this.createDirsAsync("script/assets/nested_create_dirs_demo/sub"));
        if (result.get("status") == "ok") {
            Util.log("createDirsAsync ok");
        } else {
            Util.log("createDirsAsync: " + result.get("message"));
        }
    }

    prop async createDirsAsync(path) {
        Util.newMicrotask(fun(resolve) {
            Util.log("run createDirsAsync");
            File.createDirs(path, resolve);
        });
    }

    prop async fileCreateDelete() {
        var path = "script/assets/file_delete_test/demofile";
        var result = (await this.createFileAsync(path));
        if (result.get("status") == "ok") {
            Util.log("createFileAsync ok");
        } else {
            Util.log("createFileAsync: " + result.get("message"));
        }

        result = (await this.deleteFileAsync(path));
        if (result.get("status") == "ok") {
            Util.log("deleteFileAsync ok");
        } else {
            Util.log("deleteFileAsync: " + result.get("message"));
        }
    }

    prop async createFileAsync(path) {
        Util.newMicrotask(fun(resolve) {
            Util.log("run createFileAsync");
            File.create(path, resolve);
        });
    }

    prop async deleteFileAsync(path) {
        Util.newMicrotask(fun(resolve) {
            Util.log("run deleteFileAsync");
            File.delete(path, resolve);
        });
    }

    prop async readFilePromise() {
        Util.log("run readFilePromise");
        Util.newMicrotask(fun(resolve) {
            Util.log("run readFilePromise1");
            File.read("vm_test.json", resolve);
        });
    }

    prop async jsonRead() {
        var result = (await this.readFilePromise());
        if (result.get("status") != "ok") {
            Util.log("readFilePromise: " + result.get("message"));
            return;
        }
        var text = result.get("data");
        Util.log("jsonRead json is " + text);
        var obj = Json.parse(text);

        Util.log("my name is " + obj.nickname.get(0));
        Util.log("my height is " + obj.height);

        var str = Json.toString(body);
        Util.log("Json String is " + str);
    }
}

var pe = new(PrinterExt);
printlog(p, pe.multiply(30, 41));
printlog(pe, pe.multiply(30, 42));
