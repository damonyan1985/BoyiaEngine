{
  "scopeName": "source.boyia",
  "patterns": [
    {
      "include": "#expression"
    }
  ],
  "repository": {
    "expression": {
      "patterns": [
        {
          "include": "#keyword"
        },
        {
          "include": "#keyword-control"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#new-constructor-call"
        },
        {
          "include": "#parameters"
        },
        {
          "include": "#constants"
        },
        {
          "include": "#class-declaration-name"
        },
        {
          "include": "#function-def-name"
        },
        {
          "include": "#comments"
        },
        {
          "include": "#constants-and-special-vars"
        },
        {
          "include": "#expression-brackets"
        },
        {
          "include": "#code-expression-base"
        },
        {
          "include": "#code-expression"
        },
        {
          "include": "#operators"
        }
      ]
    },
    "class-declaration-name": {
      "patterns": [
        {
          "name": "entity.name.type.class.boyia",
          "match": "(?x) (?<= \\b class \\s+ ) \\b ([[:alpha:]_]\\w*) \\b"
        },
        {
          "name": "entity.other.inherited-class.boyia",
          "match": "(?x) (?<= \\b extends \\s+ ) \\b ([[:alpha:]_]\\w*) \\b"
        }
      ]
    },
    "keyword": {
      "match": "\\b(?:class|fun|prop|var|extends|this|super|async|await|for|break|null|new|require)\\b",
      "name": "keyword.letter.boyia"
    },
    "keyword-control": {
      "match": "\\b(?:return|if|elif|else|do|while)\\b",
      "name": "keyword.control.boyia"
    },
    "constants": {
      "patterns": [
        {
          "match": "true|false",
          "name": "constant.language.boolean.boyia"
        }
      ]
    },
    "function-def-name": {
      "patterns": [
        {
          "name": "entity.name.function.boyia",
          "match": "(?x) (?<= \\b fun \\s+ ) \\b ([[:alpha:]_]\\w*) \\b"
        },
        {
          "name": "entity.name.function.boyia",
          "match": "(?x) (?<= \\b prop \\s+ async \\s+ fun \\s+ ) \\b ([[:alpha:]_]\\w*) \\b"
        },
        {
          "name": "entity.name.function.boyia",
          "match": "(?x) (?<= \\b prop \\s+ fun \\s+ ) \\b ([[:alpha:]_]\\w*) \\b"
        }
      ]
    },
    "code-expression-base": {
      "patterns": [
        {
          "name": "variable.other.readwrite.boyia",
          "match": "\\b[[:alpha:]_][[:alnum:]_]*\\b"
        }
      ]
    },
    "code-expression": {
      "patterns": []
    },
    "expression-brackets": {
      "patterns": [
        {
          "name": "punctuation.definition.block.boyia",
          "match": "\\{"
        },
        {
          "name": "punctuation.definition.block.boyia",
          "match": "\\}"
        },
        {
          "name": "meta.brace.square.boyia",
          "match": "\\["
        },
        {
          "name": "meta.brace.square.boyia",
          "match": "\\]"
        }
      ]
    },
    "new-constructor-call": {
      "begin": "(?x) (?<= \\b new \\s* ) ( \\() ",
      "end": "(\\))",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.arguments.begin.boyia"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.arguments.end.boyia"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#constants"
        },
        {
          "name": "entity.name.type.class.boyia",
          "match": "\\b[[:alpha:]_][[:alnum:]_]*\\b"
        },
        {
          "name": "punctuation.separator.argument.boyia",
          "match": ","
        },
        {
          "include": "#operators"
        }
      ]
    },
    "parameters": {
      "name": "meta.function.parameters.boyia",
      "begin": "(?x) (?<! \\b new \\s* ) ( \\() ",
      "end": "(\\))",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.parameters.begin.boyia"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.parameters.end.boyia"
        }
      },
      "patterns": [
        {
          "name": "keyword.operator.unpacking.parameter.boyia",
          "match": "(\\*\\*|\\*)"
        },
        {
          "match": "(?x)\n ([[:alpha:]_]\\w*)\n \\s* (?: (,) | (?=[)#\\n=]))\n",
          "captures": {
            "1": {
              "name": "variable.parameter.boyia"
            },
            "2": {
              "name": "punctuation.separator.parameters.boyia"
            }
          }
        },
        {
          "include": "#expression"
        },
        {
          "name": "punctuation.separator.parameters.boyia",
          "match": ","
        }
      ]
    },
    "expressions": {
		"patterns": [
			{
				"include": "#constants-and-special-vars"
			},
			{
				"include": "#strings"
			},
			{
				"name": "variable.other.readwrite.boyia",
				"match": "[a-zA-Z0-9_]+"
			},
			{
				"begin": "(\\{)",
				"end": "(\\})",
				"beginCaptures": {
					"1": {
						"name": "punctuation.definition.block.boyia"
					}
				},
				"endCaptures": {
					"1": {
						"name": "punctuation.definition.block.boyia"
					}
				},
				"patterns": [
					{
						"include": "#expressions"
					}
				]
			}
		]
	},
	"constants-and-special-vars": {
		"patterns": [
			{
				"name": "constant.language.boyia",
				"match": "(?<!\\$)\\b(true|false|null)\\b(?!\\$)"
			},
			{
				"name": "variable.language.boyia",
				"match": "(?<!\\$)\\b(this|super|augmented)\\b(?!\\$)"
			},
			{
				"name": "constant.numeric.boyia",
				"match": "(?<!\\$)\\b((0(x|X)[0-9a-fA-F][0-9a-fA-F_]*)|(([0-9][0-9_]*\\.?[0-9_]*)|(\\.[0-9][0-9_]*))((e|E)(\\+|-)?[0-9][0-9_]*)?)\\b(?!\\$)"
			},
			{
				"include": "#class-identifier"
			},
			{
				"include": "#function-identifier"
			}

		]
	},
	"class-identifier": {
		"patterns": [
			{
				"match": "(?<!\\$)\\b(bool|num|int|double|dynamic)\\b(?!\\$)",
				"name": "support.class.boyia"
			},
			{
				"match": "(?<!\\$)\\bvoid\\b(?!\\$)",
				"name": "storage.type.primitive.boyia"
			},
			{
				"begin": "(?<![a-zA-Z0-9_$])([_$]*[A-Z][a-zA-Z0-9_$]*)\\b",
				"end": "(?!<)",
				"beginCaptures": {
					"1": {
						"name": "support.class.boyia"
					}
				},
				"patterns": [
					{
						"include": "#type-args"
					}
				]
			}
		]
	},
	"function-identifier": {
		"patterns": [
			{
				"match": "([_$]*[a-z][a-zA-Z0-9_$]*)(<(?:[a-zA-Z0-9_$<>?]|,\\s*|\\s+extends\\s+)+>)?[!?]?\\(",
				"captures": {
					"1": {
						"name": "entity.name.function.boyia"
					},
					"2": {
						"patterns": [
							{
								"include": "#type-args"
							}
						]
					}
				}
			}
		]
	},
	"type-args": {
		"begin": "(<)",
		"end": "(>)",
		"beginCaptures": {
			"1": {
				"name": "other.source.boyia"
			}
		},
		"endCaptures": {
			"1": {
				"name": "other.source.boyia"
			}
		},
		"patterns": [
			{
				"include": "#class-identifier"
			},
			{
				"match": ","
			},
			{
				"name": "keyword.declaration.boyia",
				"match": "extends"
			},
			{
				"include": "#comments"
			}
		]
	},
	"operators": {
		"patterns": [
			{
				"name": "keyword.operator.boyia",
				"match": "(?<!\\$)\\b(is\\!?)\\b(?!\\$)"
			},
			{
				"name": "keyword.operator.ternary.boyia",
				"match": "\\?|:"
			},
			{
				"name": "keyword.operator.bitwise.boyia",
				"match": "(<<|>>>?|~|\\^|\\||&)"
			},
			{
				"name": "keyword.operator.assignment.bitwise.boyia",
				"match": "((&|\\^|\\||<<|>>>?)=)"
			},
			{
				"name": "keyword.operator.closure.boyia",
				"match": "(=>)"
			},
			{
				"name": "keyword.operator.comparison.boyia",
				"match": "(==|!=|<=?|>=?)"
			},
			{
				"name": "keyword.operator.assignment.arithmetic.boyia",
				"match": "(([+*/%-]|\\~)=)"
			},
			{
				"name": "keyword.operator.assignment.boyia",
				"match": "(=)"
			},
			{
				"name": "keyword.operator.increment-decrement.boyia",
				"match": "(\\-\\-|\\+\\+)"
			},
			{
				"name": "keyword.operator.arithmetic.boyia",
				"match": "(\\-|\\+|\\*|\\/|\\~\\/|%)"
			},
			{
				"name": "keyword.operator.logical.boyia",
				"match": "(!|&&|\\|\\|)"
			}
		]
	},
	"string-interp": {
		"patterns": [
			{
				"name": "meta.embedded.expression.boyia",
				"match": "\\$([a-zA-Z0-9_]+)",
				"captures": {
					"1": {
						"name": "variable.other.readwrite.boyia"
					}
				}
			},
			{
				"name": "meta.embedded.expression.boyia",
				"begin": "\\$\\{",
				"end": "\\}",
				"patterns": [
					{
						"include": "#expressions"
					}
				]
			},
			{
				"name": "constant.character.escape.boyia",
				"match": "\\\\."
			}
		]
	},
    "strings": {
		"patterns": [
			{
				"name": "string.interpolated.triple.double.boyia",
				"begin": "(?<!r)\"\"\"",
				"end": "\"\"\"(?!\")",
				"patterns": [
					{
						"include": "#string-interp"
					}
				]
			},
			{
				"name": "string.interpolated.triple.single.boyia",
				"begin": "(?<!r)'''",
				"end": "'''(?!')",
				"patterns": [
					{
						"include": "#string-interp"
					}
				]
			},
			{
				"name": "string.quoted.triple.double.boyia",
				"begin": "r\"\"\"",
				"end": "\"\"\"(?!\")"
			},
			{
				"name": "string.quoted.triple.single.boyia",
				"begin": "r'''",
				"end": "'''(?!')"
			},
			{
				"name": "string.interpolated.double.boyia",
				"begin": "(?<!\\|r)\"",
				"end": "\"",
				"patterns": [
					{
						"name": "invalid.string.newline",
						"match": "\\n"
					},
					{
						"include": "#string-interp"
					}
				]
			},
			{
				"name": "string.quoted.double.boyia",
				"begin": "r\"",
				"end": "\"",
				"patterns": [
					{
						"name": "invalid.string.newline",
						"match": "\\n"
					}
				]
			},
			{
				"name": "string.interpolated.single.boyia",
				"begin": "(?<!\\|r)'",
				"end": "'",
				"patterns": [
					{
						"name": "invalid.string.newline",
						"match": "\\n"
					},
					{
						"include": "#string-interp"
					}
				]
			},
			{
				"name": "string.quoted.single.boyia",
				"begin": "r'",
				"end": "'",
				"patterns": [
					{
						"name": "invalid.string.newline",
						"match": "\\n"
					}
				]
			}
		]
	},
    "comments": {
		"patterns": [
			{
				"name": "comment.block.empty.boyia",
				"match": "/\\*\\*/",
				"captures": {
					"0": {
						"name": "punctuation.definition.comment.boyia"
					}
				}
			},
			{
				"include": "#comments-inline"
			}
		]
	},
    "comments-inline": {
			"patterns": [
				{
					"include": "#comments-block"
				},
				{
					"match": "((//).*)$",
					"captures": {
						"1": {
							"name": "comment.line.double-slash.boyia"
						}
					}
				}
			]
		},
		"comments-block": {
			"patterns": [
				{
					"name": "comment.block.boyia",
					"begin": "/\\*",
					"end": "\\*/",
					"patterns": [
						{
							"include": "#comments-block"
						}
					]
				}
			]
		}
	}
}